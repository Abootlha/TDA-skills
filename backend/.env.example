# Server
PORT=8080
GIN_MODE=debug
ENV=development

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tdaskills
POSTGRES_USER=tdaskills
POSTGRES_PASSWORD=tdaskills_dev_pass
POSTGRES_MAX_CONN=25
POSTGRES_IDLE_CONN=5
POSTGRES_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=tdaskills_redis_pass
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-32-char-secret!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=tdaskills
CLOUDFLARE_R2_PUBLIC_URL=https://tdaskills.r2.dev
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=TDA Skills
SMTP_FROM_EMAIL=noreply@tdaskills.co.uk

# Admin
ADMIN_IP_WHITELIST=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# WebSocket
WS_PORT=8081
